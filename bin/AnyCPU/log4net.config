<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <configSections>
    <!--在配置选项中加入log4net的引用-->
    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net"/>
  </configSections>
  
  <log4net>
    <!--错误日志类-->
    <logger name="loggerWarn">
      <!--日志类的名字-->
      <level value="ALL" />
      <!--定义记录的日志级别-->
      <!-- Level的级别，由高到低 -->
      <!-- None > Fatal > ERROR > WARN > DEBUG > INFO > ALL-->
      <!-- 解释：如果level是ERROR，则在cs文件里面调用log4net的info()方法，则不会写入到日志文件中-->
      
      <appender-ref ref="LogWarnAppender" />
      <!--记录到哪个介质中去-->
    </logger>
    
    <!--信息日志类-->
    <logger name="loginfo">
      <level value="ALL" />
      <appender-ref ref="InfoAppender" />
    </logger>

    <!--信息日志类-->
    <logger name="logerror">
      <level value="ALL" />
      <appender-ref ref="LogErrorAppender" />
    </logger>
	
	<!--信息日志类-->
    <logger name="logcustom">
      <level value="ALL" />
      <appender-ref ref="LogCustomAppender" />
    </logger>

    <!--信息日志类-->
    <logger name="logaction">
      <level value="ALL" />
      <appender-ref ref="LogActionAppender" />
    </logger>
    
    
    <!--警告日志附加介质-->
    <appender name="LogWarnAppender" type="log4net.Appender.RollingFileAppender">
      <!-- name属性指定其名称,type则是log4net.Appender命名空间的一个类的名称,意思是,指定使用哪种介质-->
      <param name="File" value="D:\\NSLog\\" />
      <!--日志输出到exe程序这个相对目录下-->
      <param name="AppendToFile" value="true" />
      <!--输出的日志不会覆盖以前的信息-->
      <param name="MaxSizeRollBackups" value="100" />
      <!--备份文件的个数-->
      <param name="maximumFileSize" value="10MB" />
      <!--单个日志文件的最大大小-->
      <param name="StaticLogFileName" value="false" />
      <!--是否使用静态文件名-->
      <param name="DatePattern" value="yyyyMMdd\\'warn'yyyyMMdd&quot;.log&quot;" />
      <!--日志文件名-->
      <!--param name="RollingStyle" value="Date" /-->
      <param name="RollingStyle" value="Composite" />
      <!--文件创建的方式，这里是以Date方式创建-->
      <param name="PreserveLogFileNameExtension" value="true" />
      <!--错误日志布局-->
      <layout type="log4net.Layout.PatternLayout">
        <param name="ConversionPattern" value="%m"/>
        <!--<param name="ConversionPattern" value="异常时间：%d [%t] | 异常级别：%-5p | 异 常 类：%c [%x] : %m %n"/>-->
        <!--<param name="ConversionPattern" value="&lt;HR COLOR=red&gt;%n异常时间：%d [%t] &lt;BR&gt;%n异常级别：%-5p &lt;BR&gt;%n异 常 类：%c [%x] &lt;BR&gt;%n%m &lt;BR&gt;%n &lt;HR Size=1&gt;"  />-->
    </layout>
    </appender>
    
    <!--信息日志附加介质-->
    <appender name="InfoAppender" type="log4net.Appender.RollingFileAppender">
      <param name="File" value="D:\\NSLog\\" />
      <param name="AppendToFile" value="true" />
      <!--param name="MaxFileSize" value="10MB" /-->
      <param name="maximumFileSize" value="10MB" />
      <param name="MaxSizeRollBackups" value="100" />
      <param name="StaticLogFileName" value="false" />
      <!--param name="DatePattern" value="yyyyMMdd&quot;.txt&quot;" /-->
      <!--这是按日期产生文件夹，并在文件名前也加上日期-->
      <!--param name="DatePattern" value="yyyyMMdd\\yyyyMMdd&quot;.log&quot;"/-->
      <param name="DatePattern" value="yyyyMMdd\\'info'yyyyMMdd&quot;.log&quot;"/>
      <param name="PreserveLogFileNameExtension" value="true" />
      <!--param name="RollingStyle" value="Date" /-->
      <param name="RollingStyle" value="Composite" />
      <param name="StaticLogFileName" value="false" />
      <!--是否使用静态文件名-->
      <!--信息日志布局-->
      <layout type="log4net.Layout.PatternLayout">
        <param name="ConversionPattern" value="%m"/>
        <!--<param name="ConversionPattern" value="异常时间：%d [%t] | 异常级别：%-5p | 异 常 类：%c [%x] : %m %n"/>-->
        <!-->param name="ConversionPattern" value="&lt;HR COLOR=red&gt;%n异常时间：%d [%t] &lt;BR&gt;%n异常级别：%-5p &lt;BR&gt;%n异 常 类：%c [%x] &lt;BR&gt;%n%m &lt;BR&gt;%n &lt;HR Size=1&gt;"  /-->
    </layout>
    </appender>

    <!--错误日志附加介质-->
    <appender name="LogErrorAppender" type="log4net.Appender.RollingFileAppender">
      <param name="File" value="D:\\NSLog\\" />
      <param name="AppendToFile" value="true" />
      <!--param name="MaxFileSize" value="10MB" /-->
      <param name="maximumFileSize" value="10MB" />
      <param name="MaxSizeRollBackups" value="100" />
      <param name="StaticLogFileName" value="false" />
      <!--param name="DatePattern" value="yyyyMMdd&quot;.txt&quot;" /-->
      <!--这是按日期产生文件夹，并在文件名前也加上日期-->
      <param name="DatePattern" value="yyyyMMdd\\'error'yyyyMMdd&quot;.log&quot;"/>
      <!--param name="RollingStyle" value="Date" /-->
      <param name="RollingStyle" value="Composite" />
      <param name="PreserveLogFileNameExtension" value="true" />
      <param name="StaticLogFileName" value="false" />
      <!--是否使用静态文件名-->
      <!--信息日志布局-->
      <layout type="log4net.Layout.PatternLayout">
        <param name="ConversionPattern" value="%m"/>
        <!--<param name="ConversionPattern" value="异常时间：%d [%t] | 异常级别：%-5p | 异 常 类：%c [%x] : %m %n"/>-->
        <!-->param name="ConversionPattern" value="&lt;HR COLOR=red&gt;%n异常时间：%d [%t] &lt;BR&gt;%n异常级别：%-5p &lt;BR&gt;%n异 常 类：%c [%x] &lt;BR&gt;%n%m &lt;BR&gt;%n &lt;HR Size=1&gt;"  /-->
      </layout>
    </appender>
	
	
    <!--自定义日志附加介质-->
    <appender name="LogCustomAppender" type="log4net.Appender.RollingFileAppender">
      <param name="File" value="D:\\NSLog\\" />
      <param name="AppendToFile" value="true" />
      <!--param name="MaxFileSize" value="10MB" /-->
      <param name="maximumFileSize" value="10MB" />
      <param name="MaxSizeRollBackups" value="100" />
      <param name="StaticLogFileName" value="false" />
      <!--param name="DatePattern" value="yyyyMMdd&quot;.txt&quot;" /-->
      <!--这是按日期产生文件夹，并在文件名前也加上日期-->
      <param name="DatePattern" value="yyyyMMdd\\'custom'yyyyMMdd&quot;.log&quot;"/>
      <!--param name="RollingStyle" value="Date" /-->
      <param name="RollingStyle" value="Composite" />
      <param name="PreserveLogFileNameExtension" value="true" />
      <param name="StaticLogFileName" value="false" />
      <!--是否使用静态文件名-->
      <!--信息日志布局-->
      <layout type="log4net.Layout.PatternLayout">
        <param name="ConversionPattern" value="%m"/>
		<!--param name="ConversionPattern" value="异常时间：%d [%t] | 异常级别：%-5p | 异 常 类：%c [%x] : %m %n"  /-->
        <!-->param name="ConversionPattern" value="&lt;HR COLOR=red&gt;%n异常时间：%d [%t] &lt;BR&gt;%n异常级别：%-5p &lt;BR&gt;%n异 常 类：%c [%x] &lt;BR&gt;%n%m &lt;BR&gt;%n &lt;HR Size=1&gt;"  /-->
      </layout>
    </appender>

    <!--流程指令日志附加介质-->
    <appender name="LogActionAppender" type="log4net.Appender.RollingFileAppender">
      <param name="File" value="D:\\NSLog\\" />
      <param name="AppendToFile" value="true" />
      <!--param name="MaxFileSize" value="10MB" /-->
      <param name="maximumFileSize" value="10MB" />
      <param name="MaxSizeRollBackups" value="100" />
      <param name="StaticLogFileName" value="false" />
      <!--param name="DatePattern" value="yyyyMMdd&quot;.txt&quot;" /-->
      <!--这是按日期产生文件夹，并在文件名前也加上日期-->
      <param name="DatePattern" value="yyyyMMdd\\'action'yyyyMMdd&quot;.log&quot;"/>
      <!--param name="RollingStyle" value="Date" /-->
      <param name="RollingStyle" value="Composite" />
      <param name="PreserveLogFileNameExtension" value="true" />
      <param name="StaticLogFileName" value="false" />
      <!--是否使用静态文件名-->
      <!--信息日志布局-->
      <layout type="log4net.Layout.PatternLayout">
        <param name="ConversionPattern" value="%m"/>
        <!--param name="ConversionPattern" value="异常时间：%d [%t] | 异常级别：%-5p | 异 常 类：%c [%x] : %m %n"  /-->
        <!-->param name="ConversionPattern" value="&lt;HR COLOR=red&gt;%n异常时间：%d [%t] &lt;BR&gt;%n异常级别：%-5p &lt;BR&gt;%n异 常 类：%c [%x] &lt;BR&gt;%n%m &lt;BR&gt;%n &lt;HR Size=1&gt;"  /-->
      </layout>
    </appender>
    
  </log4net>
</configuration>

        </member>
        <member name="M:NDataBase.CSV.RemoveColumns(System.Int32[])">
            <summary>
            删除指定的多个列。
            </summary>
            <param name="columnIds">待删除列的列的编号，可以是多个列。如果不在范围内，不会处理；如果有重复，只会处理1次。</param>
        </member>
